# Copy this to .env for local development.
# On Railway/Render/etc, set these as environment variables in the dashboard.

# Shared code everyone on your squash crew types to log in.
# CHANGE THIS — don't ship the default.
GROUP_CODE=change-me-to-something-memorable

# Port the server listens on. Most hosts set this automatically.
PORT=3000

# Where to put the SQLite file.
# On Railway, mount a Volume and set this to its path (e.g. /data/court-t.db)
# so your data survives redeploys.
DB_PATH=./court-t.db
